{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/frontend/(.*)", "dest": "/server.js" },
    { "src": "/api/(.*)",      "dest": "/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",          "dest": "/server.js" }
  ]
}
